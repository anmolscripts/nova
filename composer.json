{
  "name": "nova/framework-app",
  "description": "A lightweight file-based full stack PHP framework for shared hosting.",
  "type": "project",
  "require": {
    "php": "^8.3"
  },
  "autoload": {
    "psr-4": {
      "Nova\\": "framework/"
    },
    "files": [
      "bootstrap/helpers.php"
    ]
  },
  "scripts": {
    "nova": "php nova"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
